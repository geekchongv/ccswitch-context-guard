{
  "name": "ccproxy-agent",
  "version": "0.4.101",
  "description": "A Windows local context-protection gateway for Claude Code and Claude Desktop behind CC Switch.",
  "type": "module",
  "main": "dist/electron-main.js",
  "bin": {
    "ccproxy-agent": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean:dist": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build:gui": "npm run clean:dist && npm run build && node scripts/build-gui.mjs",
    "bundle:pkg": "esbuild ././src/index.ts --bundle --platform=node --format=cjs --outfile=build/pkg/index.cjs",
    "dev": "tsx src/index.ts",
    "dev:gui": "npm run build:gui && electron .",
    "start": "node dist/index.js",
    "check": "tsc --noEmit -p tsconfig.json",
    "check:gui": "node scripts/validate-gui-refs.mjs",
    "check:package-secrets": "node scripts/validate-package-secrets.mjs",
    "smoke:packaged": "node scripts/smoke-packaged-rescue.mjs",
    "probe": "tsx src/probe.ts",
    "test": "tsx --test src/**/*.test.ts",
    "package:exe": "npm run build && npm run bundle:pkg && pkg build/pkg/index.cjs --targets node18-win-x64 --output release/ccproxy-agent.exe && powershell -NoProfile -Command \"New-Item -ItemType Directory -Force release | Out-Null; Copy-Item config.json release\\config.json -Force\"",
    "package:gui": "node scripts/package-gui.mjs --win",
    "package:gui:mac": "node scripts/package-gui.mjs --mac",
    "build:icon": "node scripts/render-icon.mjs"
  },
  "keywords": [
    "proxy",
    "ccswitch",
    "claude",
    "multimodal",
    "token-budget"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/geekchongv/ccswitch-context-guard.git"
  },
  "bugs": {
    "url": "https://github.com/geekchongv/ccswitch-context-guard/issues"
  },
  "homepage": "https://github.com/geekchongv/ccswitch-context-guard#readme",
  "author": "geekchongv",
  "license": "MIT",
  "pkg": {
    "scripts": [
      "build/pkg/**/*.cjs"
    ],
    "assets": [
      "config.example.json",
      "README.md",
      "LICENSE",
      "CHANGELOG.md",
      "SECURITY.md",
      "docs/**/*"
    ]
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "pkg": "^5.8.1",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3"
  },
  "build": {
    "appId": "local.ccproxy.agent",
    "productName": "CCProxy Agent",
    "directories": {
      "output": "release-gui"
    },
    "files": [
      "dist/**/*",
      "config.example.json",
      "README.md",
      "LICENSE",
      "CHANGELOG.md",
      "SECURITY.md",
      "docs/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.png",
      "target": [
        "portable"
      ],
      "artifactName": "CCProxy-Agent-v${version}.${ext}"
    },
    "mac": {
      "icon": "build/icon.png",
      "category": "public.app-category.developer-tools",
      "identity": null,
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "CCProxy-Agent-v${version}-${arch}.${ext}"
    }
  },
  "dependencies": {
    "tokenx": "^1.3.0"
  }
}
